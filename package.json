{
  "name": "probate-hq",
  "version": "1.3.4",
  "description": "NY Surrogate's Court Probate HQ",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-server": "bash build-server.sh",
    "build": "node bump-and-build.js",
    "build:nobump": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Jessica Wilson",
  "license": "ISC",
  "build": {
    "appId": "com.probatehq.app",
    "productName": "Probate HQ",
    "mac": {
      "category": "public.app-category.business",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "Probate HQ",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "login.html"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app",
        "filter": [
          "app.py",
          "generators.py",
          "cases.json",
          "contacts.json",
          "requirements.txt",
          "static/**/*",
          "templates/**/*",
          "Accounting/**/*",
          "*.pdf",
          "favicon.svg",
          ".env"
        ]
      },
      {
        "from": "dist/probate-server",
        "to": "probate-server"
      }
    ],
    "asar": false
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
